<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.SPGram" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
    </style>

    <style name="Theme.SPGram.Startup" parent="Theme.SPGram">
        <item name="android:windowBackground">@drawable/startup_background</item>
    </style>

    <style name="Theme.SPGram.Startup.Light" parent="Theme.SPGram">
        <item name="android:windowBackground">@drawable/startup_background_light</item>
    </style>

    <style name="Theme.SPGram.Startup.Dark" parent="Theme.SPGram">
        <item name="android:windowBackground">@drawable/startup_background_dark</item>
    </style>
</resources>
